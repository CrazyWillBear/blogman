# Neon Postgres connection string (Project → Connect → Connection string)
DATABASE_URL=

# Auth.js secret — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=

# GitHub OAuth app credentials
# Callback URL: <your-site>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Comma-separated GitHub logins allowed into /admin
ADMIN_GITHUB_LOGINS=

# Canonical site URL (optional) — full URL, no trailing slash.
# On Vercel this auto-derives from VERCEL_PROJECT_PRODUCTION_URL; set it only
# to override (e.g. a custom domain or local testing).
# SITE_URL=https://blog.williamchastain.com
